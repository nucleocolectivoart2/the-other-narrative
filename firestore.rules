/**
 * FIREBASE SECURITY RULES - THE OTHER NARRATIVE
 * DEPLOYMENT TRIGGER: V15 - Prioritized Email Authorization
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Autorización por email directo (Bootstrap de seguridad)
    function isAuthorizedEmail() {
      return isSignedIn() && (
        request.auth.token.email == 'angelamgomez@gmail.com' || 
        request.auth.token.email == 'nucleo.colectivo.art@gmail.com'
      );
    }

    // Verifica el rol administrativo en Firestore o por email directo
    function isAdmin() {
      return isAuthorizedEmail() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/adminRoles/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // --- REGLAS DE COLECCIONES ---

    match /adminRoles/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin(); 
    }

    function allowPublicRead() {
      return true;
    }

    // Colecciones de Contenido: Lectura pública, escritura solo Admin
    match /contentItems/{id} { allow read: if allowPublicRead(); allow write: if isAdmin(); }
    match /podcasts/{id} { allow read: if allowPublicRead(); allow write: if isAdmin(); }
    match /projects/{id} { allow read: if allowPublicRead(); allow write: if isAdmin(); }
    match /resources/{id} { allow read: if allowPublicRead(); allow write: if isAdmin(); }
    match /recognitions/{id} { allow read: if allowPublicRead(); allow write: if isAdmin(); }
    match /testimonials/{id} { allow read: if allowPublicRead(); allow write: if isAdmin(); }
    match /featuredVideos/{id} { allow read: if allowPublicRead(); allow write: if isAdmin(); }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}